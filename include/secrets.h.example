#pragma once

#define WIFI_SSID     "your_ssid"
#define WIFI_PASSWORD "your_password"

// Credentials OVH SMS — https://www.ovh.com/manager/sms
#define OVH_SMS_ACCOUNT  "sms-XXXXXXX"    // compte SMS OVH
#define OVH_SMS_LOGIN    "XXXXXXX"         // identifiant OVH
#define OVH_SMS_PASSWORD "XXXXXXX"         // mot de passe OVH
#define OVH_SMS_FROM     "XXXXXXX"         // expéditeur (nom alphanumérique ou numéro)
#define OVH_SMS_TO       "+336XXXXXXXX"    // destinataire (format international)

// Credentials LoRaWAN
// DevEUI : dérivé automatiquement du MAC WiFi ESP32 (EUI-64 IEEE, affiché au démarrage)
#define LORAWAN_JOIN_EUI       0x0000000000000000ULL  // JoinEUI 8 octets (ex. "ABEILLES" = 0x414245494C4C4553)
#define LORAWAN_APPKEY_PREFIX  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00  // 11 octets prefix AppKey
